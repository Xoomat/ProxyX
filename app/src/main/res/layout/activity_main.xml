<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/homeTab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="34dp"
                android:paddingEnd="22dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/logoImage"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:contentDescription="@string/app_name"
                        android:src="@drawable/logo_mark" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/title_proxy"
                                android:textColor="#EAF0FA"
                                android:textSize="30sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/title_x"
                                android:textColor="#5857FF"
                                android:textSize="30sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/versionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="-2dp"
                            android:paddingStart="6dp"
                            android:text="@string/version_text"
                            android:textColor="#EAF0FA"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="120dp" />

                <FrameLayout
                    android:id="@+id/proxyToggleCard"
                    android:layout_width="match_parent"
                    android:layout_height="116dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/bg_toggle_container"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="12dp">

                    <LinearLayout
                        android:id="@+id/stateIconPanel"
                        android:layout_width="150dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:background="@drawable/bg_state_off"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/stateIcon"
                            android:layout_width="66dp"
                            android:layout_height="66dp"
                            android:contentDescription="@string/state_icon_desc"
                            android:src="@drawable/proxy_off_icon" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/stateText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_horizontal"
                    android:text="@string/state_off"
                    android:textColor="#EAF0FA"
                    android:textSize="22sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/proxy_status_prefix"
                        android:textColor="#EAF0FA"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/statusValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/proxy_status_off"
                        android:textColor="#D12222"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="140dp" />

                <LinearLayout
                    android:id="@+id/addProxyCard"
                    android:layout_width="match_parent"
                    android:layout_height="78dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:contentDescription="@string/add_proxy"
                        android:src="@drawable/qr_code_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="@string/add_proxy"
                        android:textColor="#EAF0FA"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/settingsTab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="34dp"
                android:paddingEnd="22dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_title"
                    android:textColor="#EAF0FA"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/settings_proxy_ip"
                    android:textColor="#EAF0FA"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/hostInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_action_card"
                    android:inputType="text"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:textColor="#EAF0FA"
                    android:textColorHint="#8FA2B8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_proxy_port"
                    android:textColor="#EAF0FA"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/portInput"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_action_card"
                    android:inputType="number"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:textColor="#EAF0FA"
                    android:textColorHint="#8FA2B8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/settings_dc_mappings"
                    android:textColor="#EAF0FA"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/dcMappingsInput"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_action_card"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:padding="12dp"
                    android:textColor="#EAF0FA"
                    android:textColorHint="#8FA2B8" />

                <CheckBox
                    android:id="@+id/verboseCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_verbose"
                    android:textColor="#EAF0FA" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_hint_restart"
                    android:textColor="#9BAEC4"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/saveSettingsButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="@string/settings_save" />

                    <Button
                        android:id="@+id/resetSettingsButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/settings_reset" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/checkUpdateCard"
                    android:layout_width="match_parent"
                    android:layout_height="78dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:contentDescription="@string/check_updates"
                        android:src="@drawable/check_update_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="@string/check_updates"
                        android:textColor="#EAF0FA"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="@string/nav_home"
                android:src="@drawable/main_page_icon" />

            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_home"
                android:textColor="#4EA7FF"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navSettingsIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="@string/nav_settings"
                android:src="@drawable/settings_page_icon" />

            <TextView
                android:id="@+id/navSettingsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_settings"
                android:textColor="#909AA8"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
